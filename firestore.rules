rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && request.auth.token.email.lower() == 'wilmerjosevegaacevedo@gmail.com';
    }
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(resource) {
      return isAuthenticated() && (
        (resource.data.created_by == request.auth.uid) ||
        (resource.data.userId == request.auth.uid) ||
        (request.auth.token.email != null && (
          (resource.data.userEmail != null && resource.data.userEmail.lower() == request.auth.token.email.lower()) ||
          (resource.data.vendedor != null && resource.data.vendedor.lower() == request.auth.token.email.lower())
        ))
      );
    }

    function isCreatingWithOwnUid() {
      return isAuthenticated() && request.resource.data.created_by == request.auth.uid;
    }

    // Reglas de colecciones con multi-tenancy y bypass del administrador
    match /clientes/{document=**} {
      allow read, update, delete: if isAdmin() || isOwner(resource);
      allow create: if isAdmin() || isCreatingWithOwnUid();
    }
    
    match /productos/{document=**} {
      allow read, update, delete: if isAdmin() || isOwner(resource);
      allow create: if isAdmin() || isCreatingWithOwnUid();
    }
    
    match /ventas/{document=**} {
      allow read, update, delete: if isAdmin() || isOwner(resource);
      allow create: if isAdmin() || isCreatingWithOwnUid();
    }
    
    match /prestamos/{document=**} {
      allow read, update, delete: if isAdmin() || isOwner(resource);
      allow create: if isAdmin() || isCreatingWithOwnUid();
    }
    
    match /pagos/{document=**} {
      allow read, update, delete: if isAdmin() || isOwner(resource);
      allow create: if isAdmin() || isCreatingWithOwnUid();
    }
    
    match /gastos/{document=**} {
      allow read, update, delete: if isAdmin() || isOwner(resource);
      allow create: if isAdmin() || isCreatingWithOwnUid();
    }
    
    match /kardex/{document=**} {
      allow read, update, delete: if isAdmin() || isOwner(resource);
      allow create: if isAdmin() || isCreatingWithOwnUid();
    }
    
    // ==========================================
    // DATOS FINANCIEROS Y CONFIDENCIALES (Solo Jefe)
    // ==========================================
    match /caja/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Bloqueo general por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
